  <step>
    <name>01 - Entrada Tabla</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>PostgresSQL_Torquelab</connection>
    <sql>SELECT 
    dcat.nombre_categoria AS categoria,
    SUM(fv.precio) AS ingresos,
    SUM(fv.coste) AS costes,
    SUM(fv.beneficio) AS beneficios
FROM olap.fact_ventas fv
JOIN olap.dim_componente dc 
    ON fv.id_componente = dc.id_componente_dw
JOIN olap.dim_categoria_componente dcat
    ON dc.id_categoria_dw = dcat.id_categoria_dw
GROUP BY dcat.nombre_categoria
ORDER BY dcat.nombre_categoria;</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
