  <step>
    <name>02 - Limpieza JS</name>
    <type>ScriptValueMod</type>
    <description>Corrige errores de sensor, precipitación negativa, humedad fuera de rango, ciudades inconsistentes, temperaturas invertidas y vocabulario inválido</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// E1: nombres vacíos → NULL
if (nombre != null) {
  nombre = nombre.trim();
  if (nombre.length == 0) nombre = null;
}

if (apellido != null) {
  apellido = apellido.trim();
  if (apellido.length == 0) apellido = null;
}

// E2: email inválido → NULL
if (email != null) {
  email = email.trim().toLowerCase();
  var emailRegex = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
  if (!emailRegex.test(email)) {
    email = null;
  }
}

// E3: fecha inválida → NULL
if (fecha != null) {
  try {
    var sdf = new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm:ss");
    sdf.setLenient(false);
    fecha = sdf.parse(fecha);
  } catch (e) {
    fecha = null;
  }
}

// Campo auxiliar para lookup con dim_tiempo.fecha DATE
var fecha_solo_dia = null;

if (fecha != null) {
  var cal = java.util.Calendar.getInstance();
  cal.setTime(fecha);

  fecha_solo_dia = new java.sql.Date(
    cal.get(java.util.Calendar.YEAR) - 1900,
    cal.get(java.util.Calendar.MONTH),
    cal.get(java.util.Calendar.DAY_OF_MONTH)
  );
}

// E4: normalizar textos
if (ciudad != null) {
  ciudad = ciudad.trim().toLowerCase();
  if (ciudad.length == 0) ciudad = null;
  else ciudad = ciudad.charAt(0).toUpperCase() + ciudad.slice(1);
}

if (producto != null) {
  producto = producto.trim().toLowerCase();
  if (producto.length == 0) producto = null;
  else producto = producto.charAt(0).toUpperCase() + producto.slice(1);
}

if (categoria != null) {
  categoria = categoria.trim().toLowerCase();

  if (categoria == "motor") categoria = "Motor";
  else if (categoria == "mantenimiento") categoria = "Mantenimiento";
  else if (categoria == "freno" || categoria == "frenos") categoria = "Frenos";
  else if (categoria == "chasis") categoria = "Chasis";
  else categoria = null;
}

// E5: cantidad inválida → NULL
if (cantidad != null) {
  if (cantidad &lt;= 0) cantidad = null;
}

// E6: precio inválido → NULL
if (precio != null) {
  precio = precio.trim().replace(",", ".");
  if (precio.length == 0 || isNaN(parseFloat(precio))) {
    precio = null;
  } else {
    precio = parseFloat(precio);
  }
}

// E7: coste inválido → NULL
if (coste != null) {
  coste = coste.trim().replace(",", ".");
  if (coste.length == 0 || isNaN(parseFloat(coste))) {
    coste = null;
  } else {
    coste = parseFloat(coste);
  }
}

// Convertir a importes totales
if (precio != null &amp;&amp; coste != null &amp;&amp; cantidad != null) {
  precio = precio * cantidad;
  coste = coste * cantidad;
}

// E8: beneficio
var beneficio = null;
if (precio != null &amp;&amp; coste != null) {
  beneficio = precio - coste;
}</jsScript_script>
      </jsScript>
    </jsScripts>
