      <to>06 - Ordenar (fecha, ciudad, obs_id)</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>05 - Separar FK validas vs huerfanas</from>
      <to>LOG - FK huerfanas staging</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>06 - Ordenar (fecha, ciudad, obs_id)</from>
      <to>07 - Unique Rows dedup (fecha, ciudad)</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>07 - Unique Rows dedup (fecha, ciudad)</from>
      <to>08 - Select Values (columnas finales)</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>08 - Select Values (columnas finales)</from>
      <to>09 - InsertUpdate staging.observaciones_clean</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>09 - InsertUpdate staging.observaciones_clean</from>
      <to>10 - Leer staging.observaciones_clean</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>10 - Leer staging.observaciones_clean</from>
      <to>11 - InsertUpdate olap_snow.dim_clima</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>01 - Leer raw.ventas_sucias</name>
    <type>TableInput</type>
    <description>Lee datos crudos desde el schema meteo (origen)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>PostgreSQL_Torquelab</connection>
    <sql>SELECT 
    id_venta,
    fecha,
    id_cliente,
    TRIM(nombre) AS nombre,
    TRIM(apellido) AS apellido,
    email,
    TRIM(ciudad) AS ciudad,
    id_producto,
    TRIM(producto) AS producto,
    TRIM(categoria) AS categoria,
    cantidad
FROM raw.ventas_sucias;</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
