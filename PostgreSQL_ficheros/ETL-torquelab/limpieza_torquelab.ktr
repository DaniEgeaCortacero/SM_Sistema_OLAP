      <to>09 - InsertUpdate staging.ventas_clean</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>09 - InsertUpdate staging.ventas_clean</from>
      <to>10 - Leer staging.ventas_clean</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>10 - Leer staging.ventas_clean</from>
      <to>11 - InsertUpdate olap.fact_ventas</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>04 - Lookup FK componente</from>
      <to>04 - Lookup FK cliente</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>04 - Lookup FK cliente</from>
      <to>04 - Lookup FK fecha</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>04 - Lookup FK fecha</from>
      <to>05 - Separar FK validas vs huerfanas</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>05 - Separar FK validas vs huerfanas</from>
      <to>Select LOG huerfanas</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Select LOG huerfanas</from>
      <to>LOG - FK huerfanas staging</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>01 - Leer raw.ventas_sucias</name>
    <type>TableInput</type>
    <description>Lee datos crudos desde el schema meteo (origen)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>PostgresSQL_Torquelab</connection>
    <sql>SELECT 
    id_venta,
    fecha,
    id_cliente,

    TRIM(nombre) AS nombre,
    TRIM(apellido) AS apellido,

    LOWER(TRIM(email)) AS email,

    INITCAP(TRIM(ciudad)) AS ciudad,

    id_producto,

    INITCAP(TRIM(producto)) AS producto,

    LOWER(TRIM(categoria)) AS categoria,

    cantidad,

    TRIM(precio) AS precio,
    TRIM(coste) AS coste

FROM raw.ventas_sucias;</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
