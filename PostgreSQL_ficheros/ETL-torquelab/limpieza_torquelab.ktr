  <step>
    <name>10 - Leer staging.observaciones_clean</name>
    <type>TableInput</type>
    <description>Relée datos limpios de staging para calcular columnas derivadas y cargar el DW</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection/>
    <sql>SELECT
    oc.observacion_id,
    oc.fecha,
    oc.ciudad,
    oc.estacion_id,
    oc.temp_max,
    oc.temp_min,
    oc.temp_media,
    oc.precipitacion_mm,
    oc.humedad_pct,
    oc.velocidad_viento_kmh,
    oc.condicion_climatica,
    EXTRACT(YEAR  FROM oc.fecha)::INT AS anio,
    EXTRACT(MONTH FROM oc.fecha)::INT AS mes,
    EXTRACT(DOY   FROM oc.fecha)::INT AS dia_del_anio,
    CASE WHEN oc.precipitacion_mm > 1.0 THEN true ELSE false END AS es_dia_lluvia,
    CASE
        WHEN oc.temp_media IS NULL  THEN 'Desconocida'
        WHEN oc.temp_media &lt; 0   THEN 'Muy fria'
        WHEN oc.temp_media &lt; 10  THEN 'Fria'
        WHEN oc.temp_media &lt; 20  THEN 'Templada'
        ELSE 'Calurosa'
    END AS categoria_temperatura
FROM staging.observaciones_clean oc
ORDER BY oc.fecha, oc.ciudad</sql>
    <limit>0</limit>
